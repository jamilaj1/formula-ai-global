# ============================================================
# Formula AI Global — Environment Template
# Copy this file to .env and fill in real values
# ============================================================

# ---------- Supabase (database + auth) ----------
# Get these from: https://supabase.com/dashboard > [your project] > Settings > API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_KEY=eyJhbGciOi...
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ---------- Anthropic (Claude AI brain) ----------
# Get from: https://console.anthropic.com > API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250114

# ---------- Stripe (payments) ----------
# Get from: https://dashboard.stripe.com > Developers > API Keys
# Use test keys (pk_test_, sk_test_) until ready for live
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---------- Google AdSense (free-tier ads) ----------
NEXT_PUBLIC_ADSENSE_ID=pub-XXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_BANNER_SLOT=1234567890
NEXT_PUBLIC_ADSENSE_SIDEBAR_SLOT=0987654321

# ---------- App URLs ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:8080

# ---------- Optional: Redis (caching) ----------
REDIS_URL=redis://localhost:6379

# ---------- Optional: Sentry (error monitoring) ----------
SENTRY_DSN=https://...

# ---------- Optional: Resend (email delivery) ----------
RESEND_API_KEY=re_...

# ---------- Telegram bot ----------
# Talk to @BotFather on Telegram, /newbot, paste token here
TELEGRAM_BOT_TOKEN=

# ---------- Twilio (WhatsApp bot) ----------
# https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
