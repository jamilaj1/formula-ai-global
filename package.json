{
  "name": "formula-ai-global",
  "version": "1.0.0",
  "description": "Formula AI Global — AI chemical formulation platform (jamilformula.com)",
  "private": true,
  "type": "module",
  "scripts": {
    "build:worker": "esbuild worker-src/index.js --bundle --format=esm --target=es2022 --platform=neutral --outfile=worker.js --legal-comments=inline",
    "build:worker:watch": "esbuild worker-src/index.js --bundle --format=esm --target=es2022 --platform=neutral --outfile=worker.js --watch",
    "deploy:worker": "npm run build:worker && wrangler deploy",
    "lint": "eslint \"worker-src/**/*.js\" assets/*.js tests/**/*.js",
    "lint:fix": "eslint --fix \"worker-src/**/*.js\" assets/*.js tests/**/*.js",
    "format": "prettier --write \"**/*.{js,json,html,css,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{js,json,html,css,md}\" --ignore-path .gitignore",
    "test": "npm run build:worker && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@vitest/coverage-v8": "^2.1.4",
    "esbuild": "^0.28.0",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Jamil Abduljalil <jamilaj1@gmail.com>",
  "homepage": "https://jamilformula.com",
  "license": "UNLICENSED"
}
