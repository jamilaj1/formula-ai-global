# ==========================================================================
# Formula AI Global - Environment Variables
# Copy this file to .env.local (in the frontend/ folder) and fill in values.
# .env.local is git-ignored.
# In Vercel, configure these under Project Settings > Environment Variables.
# ==========================================================================

# --- Anthropic (Claude) ---
# Required for /api/brain to work.
# Get a key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default Claude model
# Examples: claude-sonnet-4-5 | claude-opus-4-6 | claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Supabase ---
# Project URL and anon (public) key from https://app.supabase.com -> Project Settings -> API
# These are exposed to the browser; only the anon key, never the service_role key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- App URL (optional) ---
# Used in absolute redirect URLs. Leave blank for auto-detect from request.
NEXT_PUBLIC_APP_URL=https://jamilformula.com
