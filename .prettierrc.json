{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "tabWidth": 2,
  "printWidth": 100,
  "arrowParens": "always",
  "endOfLine": "lf",
  "overrides": [
    {
      "files": "*.md",
      "options": { "printWidth": 80, "proseWrap": "preserve" }
    },
    {
      "files": ["*.html"],
      "options": { "printWidth": 120 }
    }
  ]
}
