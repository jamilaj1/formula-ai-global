+  <script src="./assets/chem-client.js?v=10"></script>
+  <script>
+  /* formula.html — single-formula presentation page.
+     Reached as formula.html?id=<uuid>  (or ?name=<text> fallback).
+     Pure addition: reads existing formulas table via window.FAI_DB. */
+  (function () {
+    const $ = (id) => document.getElementById(id);
+    const qs = new URLSearchParams(location.search);
+    const fid = qs.get('id');
+    const fname = qs.get('name');
+
+    let FORMULA = null;
+    let IS_PAID = false;
+
+    function upgradeModal() {
+      if (document.getElementById('fx-modal-bg')) return;
+      const bg = document.createElement('div');
+      bg.className = 'fx-modal-bg';
+      bg.id = 'fx-modal-bg';
+      bg.innerHTML = `
+        <div class="fx-modal">
+          <div style="font-size:2.4rem;margin-bottom:8px;">🔒</div>
+          <h3 data-i18n-ar="ميزة للأعضاء فقط">Members-only feature</h3>
+          <p data-i18n-ar="هذه التركيبة الكاملة والأدوات متاحة للمشتركين فقط. اختر خطة لفتح كل شيء.">This full formulation and its tools are available to members only. Choose a plan to unlock everything.</p>
+          <a href="./pricing.html" class="btn btn-primary" data-i18n-ar="افتح الفورمولا الكاملة">Unlock full formula</a>
+          <button class="btn btn-ghost" id="fx-modal-close" data-i18n-ar="لاحقاً">Maybe later</button>
+        </div>`;
+      bg.addEventListener('click', (e) => { if (e.target === bg) bg.remove(); });
+      document.body.appendChild(bg);
+      const c = document.getElementById('fx-modal-close');
+      if (c) c.addEventListener('click', () => bg.remove());
+      if (window.applyI18n) window.applyI18n();
+    }
+
+    function esc(s) {
+      return String(s ?? '').replace(/[&<>"']/g, (c) => (
+        { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
+    }
+    function show(el) { $(el).style.display = ''; }
+    function hide(el) { $(el).style.display = 'none'; }
+    function applyLang() { if (window.applyI18n) window.applyI18n(); }
+
+    function fail(msg) {
+      hide('fx-loading'); hide('fx-content'); show('fx-error');
+      if (msg) $('fx-error-msg').textContent = msg;
+    }
+
+    // supabase-client.js loads as type="module" (deferred) so window.FAI_DB
+    // is NOT set when this classic script first runs. Poll for it (same
+    // pattern as search-live.js) instead of failing instantly.
+    function whenDbReady(fn) {
+      if (window.FAI_DB) return fn();
+      let tries = 0;
+      const t = setInterval(() => {
+        if (window.FAI_DB) { clearInterval(t); fn(); }
+        else if (++tries > 120) {            // ~6s grace, then honest fail
+          clearInterval(t);
+          fail('Data client not available.');
+        }
+      }, 50);
+    }
+
+    async function load() {
+      if (!window.FAI_DB) return fail('Data client not available.');
+      try {
+        let f = null;
+        if (fid) {
+          f = await window.FAI_DB.getById(fid);
+        } else if (fname) {
+          const res = await window.FAI_DB.search(fname, { limit: 1 });
+          f = (res && (res.results || res.data || res))?.[0] || null;
+        } else {
+          return fail('No formula specified. Open a formula from search.');
+        }
+        if (!f || f.error || (!f.id && !f.name && !f.name_en)) return fail();
+        FORMULA = f;
+        try {
+          const profile = await window.FAI_DB.getProfile();
+          IS_PAID = !!(profile && (
+            profile.subscription_status === 'active' ||
+            (profile.plan && profile.plan !== 'free') ||
+            profile.subscription_plan_id
+          ));
+        } catch (_) { IS_PAID = false; }
+        render(f);
+      } catch (e) {
+        fail((e && e.message) || 'Load error.');
+      }
+    }
+
+    function comps(f) {
+      const c = f.components || f.ingredients || [];
+      return Array.isArray(c) ? c : [];
+    }
+
+    function render(f) {
+      const name = f.name_en || f.name || 'Untitled formula';
+      const name2 = (f.name && f.name !== name) ? f.name : '';
+      $('fx-name').textContent = name;
+      $('fx-name-2').textContent = name2;
+      document.title = name + ' — Formula AI Global';
+
+      // Badges
+      const cs = comps(f);
+      const enriched = cs.filter((x) => x && x.chem && x.chem.smiles).length;
+      const badges = [];
+      if (f.category) badges.push(`<span class="fx-badge">${esc(f.category)}</span>`);
+      if (f.form_type) badges.push(`<span class="fx-badge">${esc(f.form_type)}</span>`);
+      if (f.country) badges.push(`<span class="fx-badge">${esc(f.country)}</span>`);
+      if (enriched > 0) badges.push(`<span class="fx-badge ok">${enriched}/${cs.length} chem-enriched</span>`);
+      if (f.trust_score != null) {
+        const t = Number(f.trust_score);
+        badges.push(`<span class="fx-badge ${t >= 70 ? 'ok' : 'warn'}">trust ${t}</span>`);
+      }
+      $('fx-badges').innerHTML = badges.join('');
+
+      // Ingredients table
+      const tot = cs.reduce((s, x) => s + (parseFloat(x.percentage) || 0), 0);
+      const maxPct = Math.max(1, ...cs.map((x) => parseFloat(x.percentage) || 0));
+      $('fx-ing-body').innerHTML = cs.map((x, i) => {
+        const nm = esc(x.name_en || x.name || '?');
+        const ar = (x.name && x.name !== (x.name_en || x.name)) ? `<div style="font-size:0.78rem;color:var(--text-3);">${esc(x.name)}</div>` : '';
+        const pct = parseFloat(x.percentage);
+        const ch = x.chem || {};
+        const chips = [];
+        if (ch.molecular_weight) chips.push(`<span class="chem-chip">MW ${Number(ch.molecular_weight).toFixed(1)}</span>`);
+        if (ch.logp != null) chips.push(`<span class="chem-chip">logP ${Number(ch.logp).toFixed(2)}</span>`);
+        if (x.cas_number) chips.push(`<span class="chem-chip">CAS ${esc(x.cas_number)}</span>`);
+        const locked = !IS_PAID && i >= 3;
+        return `<tr${locked ? ' class="fx-locked-row"' : ''}>
+          <td style="color:var(--text-3);">${i + 1}</td>
+          <td><strong>${nm}</strong>${ar}<div>${chips.join('')}</div></td>
+          <td><span class="fn-tag">${esc(x.function || '—')}</span></td>
+          <td class="pct-cell">${isNaN(pct) ? '—' : pct + '%'}
+            ${isNaN(pct) ? '' : `<div class="pct-bar"><div style="width:${Math.min(100, pct / maxPct * 100)}%"></div></div>`}</td>
+        </tr>`;
+      }).join('') || `<tr><td colspan="4" style="color:var(--text-3);padding:20px;text-align:center;" data-i18n-ar="لا توجد مكوّنات مُسجَّلة لهذه الفورمولا.">No components recorded for this formula.</td></tr>`;
+
+      const lockNote = $('fx-lock');
+      if (!IS_PAID && cs.length > 0) {
+        lockNote.innerHTML = 'This is a members-only formula. ' + (cs.length > 3 ? (cs.length - 3) + ' of ' + cs.length + ' ingredients, the full procedure, batch scaler and safety analysis are locked. ' : 'The full procedure, batch scaler and safety analysis are locked. ') +
+          '<a href="./pricing.html" style="color:var(--primary);font-weight:700;">Unlock full formula</a>';
+        lockNote.setAttribute('data-i18n-ar', 'هذه فورمولا للأعضاء فقط. ' + (cs.length > 3 ? (cs.length - 3) + ' من ' + cs.length + ' مكوّن، وطريقة التحضير الكاملة، وحاسبة الدفعة، وتحليل السلامة مقفلة. ' : 'طريقة التحضير الكاملة، وحاسبة الدفعة، وتحليل السلامة مقفلة. ') + "<a href='./pricing.html' style='color:var(--primary);font-weight:700;'>افتح الفورمولا الكاملة</a>");
+        show('fx-lock');
+      } else if (enriched === 0 && cs.length > 0) {
+        show('fx-lock');
+      }
+
+      // Procedure
+      const proc = f.procedure || f.instructions || f.method;
+      if (proc && IS_PAID) { $('fx-procedure').textContent = proc; show('fx-procedure-panel'); }
+
+      // Stats
+      $('fx-st-count').textContent = cs.length;
+      $('fx-st-total').textContent = tot ? tot.toFixed(1) + '%' : '—';
+      $('fx-st-chem').textContent = cs.length ? `${enriched}/${cs.length}` : '—';
+      $('fx-st-trust').textContent = f.trust_score != null ? f.trust_score : '—';
+
+      // Substitute deep-link (first ingredient name prefilled)
+      if (cs[0] && (cs[0].name_en || cs[0].name)) {
+        $('fx-sub-link').href = './substitute.html?ingredient=' +
+          encodeURIComponent(cs[0].name_en || cs[0].name);
+      }
+
+      scale();
+      hide('fx-loading'); show('fx-content');
+      applyLang();
+    }
+
+    // Batch scaler — pure client-side, instant value, no backend needed.
+    function scale() {
+      if (!FORMULA) return;
+      if (!IS_PAID) {
+        $('fx-batch').disabled = true;
+        $('fx-scale-out').innerHTML = '<div class="fx-upgrade"><h4 data-i18n-ar="حاسبة الدفعة للأعضاء">Batch scaler is members-only</h4><p data-i18n-ar="افتح حساب كميات الدفعة الفوري مع العضوية.">Unlock instant batch-amount calculation with a membership.</p><a href="./pricing.html" class="btn btn-primary btn-sm" data-i18n-ar="افتح الفورمولا الكاملة">Unlock full formula</a></div>';
+        if (window.applyI18n) window.applyI18n();
+        return;
+      }
+      const kg = parseFloat($('fx-batch').value) || 0;
+      const cs = comps(FORMULA);
+      const rows = cs
+        .filter((x) => !isNaN(parseFloat(x.percentage)))
+        .map((x) => {
+          const amt = (parseFloat(x.percentage) / 100) * kg;
+          return `<div>• ${esc(x.name_en || x.name)}: <strong>${amt.toFixed(3)} kg</strong></div>`;
+        });
+      $('fx-scale-out').innerHTML = rows.length
+        ? rows.join('')
+        : '<span style="color:var(--text-3)" data-i18n-ar="لا نِسب مئوية متاحة للحساب.">No percentages available to scale.</span>';
+    }
+    $('fx-batch').addEventListener('input', scale);
+
+    // Safety analysis via existing endpoint
+    $('fx-safety-btn') && $('fx-safety-btn').addEventListener('click', async function () {
+      if (!IS_PAID) { upgradeModal(); return; }
+      const out = $('fx-safety-out');
+      out.innerHTML = '<span style="color:var(--text-3)" data-i18n-ar="جاري التحليل…">Analysing…</span>';
+      applyLang();
+      try {
+        const r = await window.FAI_DB.getSafety(FORMULA);
+        const txt = (r && (r.analysis || r.summary || r.result || r.text)) ||
+          (typeof r === 'string' ? r : JSON.stringify(r).slice(0, 800));
+        out.innerHTML = `<div style="white-space:pre-wrap;">${esc(txt)}</div>`;
+      } catch (e) {
+        out.innerHTML = `<span style="color:#ff7a7a;">${esc((e && e.message) || 'Safety analysis unavailable.')}</span>`;
+      }
+    });
+
+    whenDbReady(load);
+  })();
+  </script>
+</body>
+</html>
