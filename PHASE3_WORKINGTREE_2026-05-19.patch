+  <script type="module" src="./assets/auth.js?v=9"></script>
+  <script type="module" src="./assets/supabase-client.js?v=9"></script>
+  <script>
+  /* contribute.html — community formula upload (sign-in required).
+     Pure addition. Inserts into user_submissions via the user's own
+     authenticated Supabase client (RLS enforces submitter = self).
+     Nothing is published until the owner moderates it. */
+  (function () {
+    const $ = (id) => document.getElementById(id);
+    const els = {
+      auth: $('cb-auth'), loading: $('cb-loading'), form: $('cb-form-wrap'),
+      done: $('cb-done'), err: $('cb-err'),
+      title: $('cb-title'), type: $('cb-type'), text: $('cb-text'),
+      file: $('cb-file'), submit: $('cb-submit'), again: $('cb-again'),
+    };
+    let USER = null, CLIENT = null;
+
+    function showOnly(key) {
+      ['auth', 'loading', 'form', 'done'].forEach((k) =>
+        els[k].style.display = (k === key ? '' : 'none'));
+    }
+    function applyLang() { if (window.applyI18n) window.applyI18n(); }
+
+    // Wait for the auth module, then decide which view to show.
+    let tries = 0;
+    const wait = setInterval(async () => {
+      tries++;
+      const A = window.FAI_AUTH;
+      if (A && A.client) {
+        clearInterval(wait);
+        CLIENT = A.client;
+        try {
+          const { data: { session } } = await CLIENT.auth.getSession();
+          USER = session && session.user ? session.user : (A.user || null);
+        } catch (_) { USER = A.user || null; }
+        if (USER && USER.id) { showOnly('form'); applyLang(); }
+        else { showOnly('auth'); applyLang(); }
+      } else if (tries > 60) {     // ~3s — auth never loaded
+        clearInterval(wait);
+        showOnly('auth'); applyLang();
+      }
+    }, 50);
+
+    function readFile(file) {
+      return new Promise((resolve, reject) => {
+        const r = new FileReader();
+        const isText = /\.(csv|tsv|txt)$/i.test(file.name);
+        r.onload = () => resolve({
+          isText,
+          value: r.result,            // text OR dataURL
+          name: file.name,
+          type: file.type || 'application/octet-stream',
+        });
+        r.onerror = reject;
+        if (isText) r.readAsText(file);
+        else r.readAsDataURL(file);   // xlsx → base64 data URL
+      });
+    }
+
+    async function submit() {
+      els.err.style.display = 'none';
+      const title = els.title.value.trim();
+      const text = els.text.value.trim();
+      const f = els.file.files[0];
+
+      if (!title) return fail('Please enter a formula / product name.');
+      if (!text && !f) return fail('Paste the recipe or attach a file.');
+      if (f && f.size > 2 * 1024 * 1024) return fail('File is larger than 2 MB.');
+
+      els.submit.disabled = true;
+      els.submit.textContent = '…';
+
+      let row = {
+        submitter_id: USER.id,
+        submitter_email: USER.email || null,
+        mode: f ? 'file' : 'paste',
+        title,
+        product_type: els.type.value || null,
+        raw_text: text || null,
+        review_status: 'pending',
+      };
+
+      try {
+        if (f) {
+          const fr = await readFile(f);
+          row.file_name = fr.name;
+          row.content_type = fr.type;
+          if (fr.isText) {
+            row.raw_text = (text ? text + '\n\n---FILE---\n' : '') + fr.value;
+          } else {
+            row.file_b64 = fr.value;        // base64 data URL
+          }
+        }
+        const { error } = await CLIENT.from('user_submissions').insert([row]);
+        if (error) throw error;
+        showOnly('done'); applyLang();
+      } catch (e) {
+        fail((e && (e.message || e.error_description)) ||
+             'Could not submit. Please try again.');
+      } finally {
+        els.submit.disabled = false;
+        els.submit.innerHTML =
+          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4z"/></svg> Submit for review';
+        applyLang();
+      }
+    }
+
+    function fail(msg) {
+      els.err.textContent = msg;
+      els.err.style.display = '';
+    }
+
+    els.submit.addEventListener('click', submit);
+    els.again.addEventListener('click', () => {
+      els.title.value = ''; els.text.value = ''; els.type.value = '';
+      els.file.value = ''; showOnly('form'); applyLang();
+    });
+  })();
+  </script>
+</body>
+</html>
